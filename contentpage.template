    <section class="search-section">
        <form class="search-container" id="search-form">
            <input type="text" id="search-input" class="search-input" placeholder="Search the entire site...">
            <button type="submit" class="search-button">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>
            </button>
        </form>
    </section>

    <main class="content-container">
       
        <h3>Example Solution</h3>
        <p>(a) Velocity $\vec{v}$ is defined as the first derivative of position vector with respect to time.</p>
        $$ \vec{v} = \frac{d\vec{r}}{dt} = t\hat{i} - 2\sqrt{t}\hat{j} + 2\hat{k} \text{ m/s} $$
        
        <p>Acceleration $\vec{a}$ is defined as the first derivative of velocity vector with respect to time.</p>
        $$ \vec{a} = \frac{d\vec{v}}{dt} = \hat{i} - \frac{1}{\sqrt{t}}\hat{j} \text{ m/s}^2 $$
        
        <p>(b) Displacement $\Delta\vec{r}$ is defined as the change in place of position vector.</p>
        $$ \Delta\vec{r} = \vec{r}(4) - \vec{r}(0) = (8\hat{i} - \frac{32}{3}\hat{j} + 8\hat{k}) - (0) = 8\hat{i} - \frac{32}{3}\hat{j} + 8\hat{k} \text{ m} $$
        
        <p>Magnitude of displacement $|\Delta\vec{r}| = \sqrt{8^2 + (-\frac{32}{3})^2 + 8^2} \approx 15.55 \text{ m}$</p>
        
        <p>Distance $\Delta s$ is defined as the path length and can be calculated by integrating speed over the concerned time interval.</p>
        $$ \Delta s = \int_0^4 |\vec{v}| dt = \int_0^4 \sqrt{t^2 + (-2\sqrt{t})^2 + 2^2} dt = \int_0^4 \sqrt{t^2 + 4t + 4} dt = \int_0^4 (t+2) dt = \left[ \frac{t^2}{2} + 2t \right]_0^4 = 16 \text{ m} $$
        
    </main>

    <div id="search-results-overlay">
        <div id="search-results-box">
            <div class="search-results-header"><span>Search Results</span><button id="close-search-btn">&times;</button></div>
            <div id="search-results-list"></div>
        </div>
    </div>

    <script>
        let searchableData = [];
        const searchInput = document.getElementById('search-input');
        const searchResultsOverlay = document.getElementById('search-results-overlay');
        const searchResultsList = document.getElementById('search-results-list');
        const closeSearchBtn = document.getElementById('close-search-btn');

        document.addEventListener('DOMContentLoaded', () => {
            fetch('/contents.json')
                .then(response => response.json())
                .then(data => { searchableData = data; })
                .catch(error => console.error('Error loading search data:', error));
        });

        let debounceTimer;
        searchInput.addEventListener('keyup', () => {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => { performSearch(searchInput.value); }, 300);
        });

        document.getElementById('search-form').addEventListener('submit', e => e.preventDefault());

        function closeOverlay() { searchResultsOverlay.style.display = 'none'; }
        closeSearchBtn.addEventListener('click', closeOverlay);
        searchResultsOverlay.addEventListener('click', (event) => {
            if (event.target === searchResultsOverlay) { closeOverlay(); }
        });

        function performSearch(query) {
            if (!query || query.trim() === '') { closeOverlay(); return; }
            const scoredResults = searchableData.map(item => ({ item, score: calculateScore(item, query) }));
            const finalResults = scoredResults.filter(result => result.score > 0).sort((a, b) => b.score - a.score).map(result => result.item);
            displayResults(finalResults);
        }

        function calculateScore(item, query) {
            let score = 0;
            const lowerQuery = query.toLowerCase();
            if (item.title.toLowerCase() === lowerQuery) score += 100;
            else if (item.title.toLowerCase().startsWith(lowerQuery)) score += 50;
            else if (item.title.toLowerCase().includes(lowerQuery)) score += 20;
            if (item.description.toLowerCase().includes(lowerQuery)) score += 10;
            if (item.author.toLowerCase().includes(lowerQuery)) score += 5;
            if (item.category.toLowerCase().includes(lowerQuery)) score += 5;
            return score;
        }

        function displayResults(results) {
            searchResultsList.innerHTML = '';
            if (results.length === 0) {
                searchResultsList.innerHTML = `<p style="padding: 20px; text-align: center; color: #888;">No results found.</p>`;
            } else {
                results.forEach(item => {
                    const resultElement = document.createElement('a');
                    // FIX 2: Use absolute path directly for more robust linking.
                    resultElement.href = item.src; 
                    resultElement.classList.add('search-result-item');
                    resultElement.innerHTML = `<h3>${item.title}</h3><p>Category: ${item.category}</p>`;
                    searchResultsList.appendChild(resultElement);
                });
            }
            searchResultsOverlay.style.display = 'flex';
        }
    </script>
</body>
